{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "KalshiBotOverseer.State.OverseerReadyStatus": "Information",
      "KalshiBotOverseer.State.OverseerStatusTracker": "Information"
    }
  },
  "SignalR": {
    "HubUrl": "http://192.168.1.100:5000/chartHub"
  },
  "OverseerReadyConfig": {
    "DefaultInitializationState": false,
    "DefaultBrowserReadyState": false
  },
  "BrainPersistenceDefaults": {
    "DefaultMode": "Autonomous",
    "DefaultTargetWatches": 10,
    "DefaultMinimumInterest": 0.5,
    "DefaultUsageMin": 10.0,
    "DefaultUsageMax": 80.0
  },
  "BrainPersistenceService": {
    "MaxHistoryEntries": 50,
    "EnablePerformanceMetrics": true,
    "EnableBrainPersistenceServicePerformanceMetrics": true,
    "EnablePersistence": false,
    "PersistenceSaveIntervalMinutes": 5,
    "MetricNames": {
      "CpuUsage": "CpuUsage",
      "EventQueue": "EventQueue",
      "TickerQueue": "TickerQueue",
      "NotificationQueue": "NotificationQueue",
      "OrderbookQueue": "OrderbookQueue",
      "MarketCount": "MarketCount",
      "Error": "Error"
    }
  },
  "Performance": {
    "SnapshotAggregation": {
      "EnableMetrics": true
    }
  },
  "CacheConfig": {
    "MarketsCacheDurationMinutes": 15,
    "LogDataCacheDurationMinutes": 5
  },
  "DashboardConfig": {
    "EnableFrontendErrorReporting": true,
    "EnablePerformanceMetricsCollection": true,
    "DefaultRefreshIntervals": {
      "Global": 30000,
      "Markets": 30000,
      "Brains": 30000,
      "Positions": 30000,
      "Orders": 30000,
      "Snapshots": 30000,
      "Chart": 30000,
      "Account": 30000
    },
    "FrontendLogging": {
      "EnableBackendLogging": true,
      "LogPerformanceMetrics": true,
      "LogUserInteractions": false,
      "MaxLogMessageLength": 500,
      "LogRetentionDays": 7
    },
    "UserExperience": {
      "ShowPerformanceWarnings": true,
      "EnableAutoSaveSettings": true,
      "MinimumRefreshIntervalMs": 5000,
      "MaximumRefreshIntervalMs": 300000
    }
  },
  "OverseerConfig": {
    "ApiFetchIntervalMinutes": 10,
    "SystemInfoLogIntervalMinutes": 1,
    "SignalRBatchSize": 10,
    "BrainBatchSize": 50
  },
  "OverseerHub": {
    "ConnectionHealthTimeoutSeconds": 300,
    "HealthCheckIntervalSeconds": 60,
    "AuthTokenValidityHours": 24,
    "MaxHandshakeRequestsPerMinute": 10,
    "MaxCheckInRequestsPerMinute": 60,
    "EnablePerformanceMetrics": false
  },
  "KalshiWebSocketClient": {
    "EnablePerformanceMetrics": true
  },
  "Execution": {
    "MarketUpdateTimeout": 40000,
    "LaunchDataDashboard": false,
    "RunOvernightActivities": false,
    "BrainInstance": "WorkLaptop",
    "InterestMinimum": 5,
    "UsageTargetPercentage": 82.5,
    "UsageWarningPercentage": 90,
    "UsageMinPercentage": 70,
    "QueuesTargetCount": 15,
    "QueuesTargetPercentage": 50.0,
    "NotificationQueueLimit": 50,
    "OrderbookQueueLimit": 50,
    "EventQueueLimit": 50,
    "TickerQueueLimit": 50,
    "MaxMarketsPerSubscriptionAction": 3,
    "HardDataStorageLocation": "\\\\DESKTOP-ITC50UT\\SmokehouseDataStorage",
    "MaxWatchedMarkets": 200,
    "BroadcastIntervalSeconds": 30,
    "BroadcastMaxRetryAttempts": 3,
    "BroadcastRetryDelaySeconds": 1,
    "QueueHighCountAlertThreshold": 80.0,
    "RefreshUsageAlertThreshold": 90.0,
    "QueueCountAlertThreshold": 100,
    "RetryDelayMs": 5000,
    "SessionIdLength": 5,
    "OverseerConnectionTimeoutSeconds": 30,
    "OverseerSemaphoreTimeoutSeconds": 10,
    "OverseerDiscoveryIntervalMinutes": 3,
    "OverseerCheckInIntervalSeconds": 30,
    "OverseerCircuitBreakerFailureThreshold": 5,
    "OverseerCircuitBreakerTimeoutMinutes": 5,
    "OvernightBatchSize": 20,
    "OvernightRetryDelayMinutes": 30,
    "InterestScoreAgeThresholdHours": 12,
    "MarketRefreshCircuitBreakerFailureThreshold": 5,
    "MarketRefreshCircuitBreakerTimeoutMinutes": 5,
    "ConnectionHealthCheckIntervalSeconds": 30,
    "ConnectionHealthTimeoutSeconds": 60,
    "AuthTokenValidityHours": 24,
    "HandshakeRateLimitPerMinute": 10,
    "CheckInRateLimitPerMinute": 60,
    "MessageBatchSize": 50,
    "MessageBatchIntervalMs": 100,
    "StaleConnectionCleanupIntervalMinutes": 5,
    "MaxConnectionAgeMinutes": 10,
    "CentralPerformanceMonitor_EnableDatabaseMetrics": true
    },
    "SqlDataService": {
      "RetryCount": 3,
      "RetryDelaySeconds": 1.0,
      "MaxQueueSize": 10000,
      "WorkersPerQueue": 1,
      "BatchSize": 1,
      "EnablePerformanceMetrics": false
    },
    "ChartConfig": {
      "AskColor": "OrangeRed",
      "BidColor": "DodgerBlue",
      "BuyColor": "Green",
      "SellColor": "Red",
      "ExitColor": "Black",
      "EventColor": "Purple",
      "DiscrepancyColor": "Magenta",
      "AskSize": 4,
      "BidSize": 4,
      "BuySize": 12,
      "SellSize": 12,
      "ExitSize": 12,
      "EventSize": 0,
      "DiscrepancySize": 8
    },
    "AllowedHosts": "*"
}