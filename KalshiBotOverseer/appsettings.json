{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "KalshiBotOverseer.State.OverseerReadyStatus": "Information",
      "KalshiBotOverseer.State.OverseerStatusTracker": "Information"
    }
  },
  "SignalR": {
    "HubUrl": "http://192.168.1.100:5000/chartHub"
  },
  "OverseerReadyConfig": {
    "DefaultInitializationState": false,
    "DefaultBrowserReadyState": false
  },
  "BrainPersistenceDefaults": {
    "DefaultMode": "Autonomous",
    "DefaultTargetWatches": 10,
    "DefaultMinimumInterest": 0.5,
    "DefaultUsageMin": 10.0,
    "DefaultUsageMax": 80.0
  },
  "CacheConfig": {
    "MarketsCacheDurationMinutes": 15,
    "LogDataCacheDurationMinutes": 5
  },
  "AllowedHosts": "*"
}