    "UsageWarningPercentage": 90, // The warning percentage that will cause markets to be removed when managing the watch list
    "UsageMinPercentage": 70, // The warning percentage that will cause markets to be added when managing the watch list
    "QueuesTargetCount": 15, // The max number of items found in the three orderbookservice queues which can be considered "good performance"
    "QueuesTargetPercentage": 50.0, // he percentage of the samples that should be <= the target count to be considered "good performance"
    "MaxMarketsPerSubscriptionAction": 3, // The most markets allowed to be added to the list at one time, when managing the watch list
    "HardDataStorageLocation": "\\\\DESKTOP-ITC50UT\\SmokehouseDataStorage", //The path where hard drive precomputation data can be found
    "MaxWatchedMarkets": 200 //The maximum number of markets which can be watched.
  },
