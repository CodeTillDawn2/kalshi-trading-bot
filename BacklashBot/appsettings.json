    "OrderbookCancelWindowSeconds": 1.0, //The max number of seconds apart an orderbook change can be from a matching and opposite orderbook change without being a cancellation
    "AlwaysWatchPositions": true, //Add positions to the watchlist
    "AlwaysWatchRestingOrders": true, //Add resting orders to the watchlist
