  "Execution": {
    "MarketUpdateTimeout": 40000, // The amount of time in milliseconds to wait for a market update before timing out
    "LaunchDataDashboard": false, // Whether or not to launch the data dashboard. 
    "RunOvernightActivities": false, // Whether or not to run overnight activities.
    "BrainInstance": "WorkLaptop", // The unique name of the brain instance this is. Used for deconflicting markets with other instances.
    "InterestMinimum": 5, // The minimum score which makes a market "interesting". Ranked 0-10
