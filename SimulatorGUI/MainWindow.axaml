<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingSimulatorGUI.MainWindow"
        Width="1200" Height="800" Title="Trading Simulator">
	<DockPanel>

		<!-- Top controls -->
		<StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="8" Spacing="8">
			<TextBlock Text="Set:" VerticalAlignment="Center"/>
			<ComboBox x:Name="SetCombo" Width="180" SelectionChanged="SetCombo_SelectionChanged"/>

			<TextBlock Text="Weight:" VerticalAlignment="Center"/>
			<ComboBox x:Name="WeightCombo" Width="260"/>

			<Button Content="Run Selected" Click="RunSelected_Click"/>
			<Button Content="Run Training" Click="RunTraining_Click"/>

			<Button Content="Select All NA" Click="SelectAllNA_Click"/>
			<Button Content="Select All With Results" Click="SelectAllWithResultsButton_Click"/>
			<Button Content="Select All" Click="SelectAll_Click"/>
		</StackPanel>

		<!-- Body -->
		<Grid Margin="8" RowDefinitions="*,Auto">
			<!-- Swappable area: list vs chart -->
			<Grid>
				<!-- List panel -->
				<Grid x:Name="ListPanel" IsVisible="True">
					<DataGrid x:Name="MarketGrid"
							  AutoGenerateColumns="False"
							  IsReadOnly="True"
							  SelectionMode="Single"
							  DoubleTapped="MarketGrid_DoubleTapped">
						<DataGrid.Columns>
							<DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected}"/>
							<DataGridTextColumn Header="Market" Binding="{Binding Market}"/>
							<!-- Bind to formatted string so it’s always 2 decimals and read-only -->
							<DataGridTextColumn Header="PnL" Binding="{Binding PnLDisplay}"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>

				<!-- Chart panel -->
				<Grid x:Name="ChartPanel" IsVisible="False" RowDefinitions="Auto,*" Margin="0">
					<StackPanel Orientation="Horizontal" Spacing="8">
						<Button x:Name="BackButton" Content="Back" Click="BackButton_Click"/>
						<TextBlock x:Name="ChartTitle" VerticalAlignment="Center"/>
					</StackPanel>
					<ContentControl x:Name="ChartHost" Grid.Row="1" Margin="0,8,0,0"/>
				</Grid>
			</Grid>

			<!-- Output / summary -->
			<StackPanel Grid.Row="1" Spacing="6" Margin="0,8,0,0">
				<TextBlock x:Name="ProfitLossText" Text="Total P&amp;L: 0.00"/>
				<TextBox x:Name="TestOutput"
						 AcceptsReturn="True"
						 IsReadOnly="True"
						 Height="180"
						 ScrollViewer.HorizontalScrollBarVisibility="Auto"
						 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
			</StackPanel>
		</Grid>
	</DockPanel>
</Window>
