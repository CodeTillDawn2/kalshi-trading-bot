{
  "Secrets": {
    "SecretsPath": "C:\\KalshiData\\Secrets"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=192.168.1.210;Database=BacklashOverseer;User Id={Database:Username};Password={Database:Password};TrustServerCertificate=True;"
  },
  "Kalshi": {
    "Environment": "prd",
    "KeyId": "{Kalshi:SimulatorKeyId}",
    "KeyFile": "{Kalshi:SimulatorKeyFile}",
    "WebSocketBufferSize": 16384,
    "WebSocketMaxRetryAttempts": 5,
    "WebSocketRetryDelays": [ 1000, 2000, 4000, 8000, 16000 ],
    "WebSocketSignatureCacheDurationMinutes": 5,
    "WebSocketResetDelayMs": 5000,
    "WebSocketSemaphoreTimeoutMs": 60000,
    "WebSocketEnableMetrics": true,
    "KalshiAPIServiceEnablePerformanceMetrics": true,
    "KalshiWebSocketClient": {
      "EnableKalshiWebSocketClientPerformanceMetrics": true
    },
    "MessageProcessor": {
      "EnableMessageBatching": true,
      "MaxBatchSize": 50,
      "BatchProcessingIntervalMs": 100,
      "MaxOrderBookQueueSize": 10000,
      "OrderBookQueueTimeoutMs": 30000,
      "MaxSequenceNumbersToKeep": 10000,
      "SequenceNumberCleanupIntervalMs": 60000,
      "EnablePerformanceMetrics": true,
      "PerformanceMetricsLogIntervalMs": 30000,
      "DuplicateMessageWarningThreshold": 10,
      "DuplicateMessageTimeWindowMs": 60000,
      "UseAdvancedLocking": true
    },
    "CandlestickLookback": {
      "Minute": 3,
      "Hour": 7,
      "Day": 15
    },
    "CandlestickCushion": {
      "Minute": 60,
      "Hour": 3600,
      "Day": 86400
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "SnapshotViewer": {
    "InteractionConfig": {
      "ZoomInFactor": 0.9,
      "ZoomOutFactor": 1.1,
      "PanThreshold": 0.001,
      "NavigationTimerInterval": 300,
      "NavigationResetDelay": 500,
      "RapidNavigationThreshold": 60,
      "FastNavigationThreshold": 15,
      "MediumNavigationThreshold": 5,
      "RapidStepSize": 60,
      "FastStepSize": 5,
      "MediumStepSize": 2,
      "NormalStepSize": 1
    }
  },
  "Typography": {
    "PreferredFonts": [
      "Segoe UI",
      "Microsoft Sans Serif",
      "Arial",
      "Helvetica",
      "Tahoma",
      "Verdana",
      "Calibri",
      "System"
    ],
    "MonospaceFonts": [
      "Consolas",
      "Source Code Pro",
      "Fira Code",
      "Courier New",
      "Monaco",
      "Lucida Console",
      "DejaVu Sans Mono"
    ],
    "MinScaleFactor": 0.5,
    "MaxScaleFactor": 3.0,
    "DefaultScaleFactor": 1.0
  },
  "MarketTypeService": {
    "CacheExpirationMinutes": 30,
    "EnablePerformanceMetrics": true
  },
  "EquityCalculator": {
    "EnablePerformanceMetrics": true
  },
  "StrategySelectionHelper": {
    "EnablePerformanceMetrics": false
  },
  "MarketAnalysisHelper": {
    "MarketUpdateTimeout": 40000,
    "MaxMarketsPerSubscriptionAction": 3,
    "MaxWatchedMarkets": 200,
    "MaxCandlesticksPerMarket": 10000,
    "MaxParallelCandlestickTasks": 4,
    "MaxDegreeOfParallelismDataLoading": 2
  },
  "Snapshots": {
    "StorageDirectory": "\\\\DESKTOP-ITC50UT\\SmokehouseDataStorage\\NewSnapshots"
  },
  "TradingSimulatorService": {
    "CacheDirectory": "..\\..\\..\\..\\..\\TestingOutput",
    "ProcessingTimeoutSeconds": 300,
    "MaxConcurrentMarkets": 5,
    "BatchSize": 10,
    "MarketDataFileNamePattern": "{market}_{label}_{strategy}_{timestamp}.json",
    "ResearchBusFileNamePattern": "{label}_ResearchBus_{timestamp}.csv",
    "BestFitReportFileNamePattern": "{label}_BestFitReport_{timestamp}.csv",
    "DiscrepancyThresholdPercentage": 10,
    "EnableSnapshotValidation": true,
    "MinSnapshotCountForValidation": 1,
    "DiscrepancyDetection": {
      "Enabled": false,
      "VelocityThreshold": 0.1,
      "MinSnapshotsForDetection": 10
    }
  }
}