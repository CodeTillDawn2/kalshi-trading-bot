{
  "InstanceName": {
    "Name": "WorkLaptop"
  },
  "DataStorage": {
    "HardDataStorageLocation": "\\\\DESKTOP-ITC50UT\\SmokehouseDataStorage"
  },
  "Secrets": {
    "SecretsPath": "C:\\KalshiData\\Secrets"
  },
  "DBConnection": {
    "DefaultConnection": "Server=192.168.1.210;Database=kalshibot-prd;User Id={Database:Username};Password={Database:Password};TrustServerCertificate=True;",
    "BacklashBotData": {
      "MaxRetryCount": 3,
      "RetryDelaySeconds": 1.0,
      "BatchSize": 100,
      "MaxQueueSize": 10000,
      "WorkersPerQueue": 1,
      "EnablePerformanceMetrics": false
    }
  },
  "Kalshi": {
    "Environment": "prd",
    "KeyId": "{Kalshi:SimulatorKeyId}",
    "KeyFile": "{Kalshi:SimulatorKeyFile}",
    "KalshiWebSocketClient": {
      "EnableKalshiWebSocketClientPerformanceMetrics": true
    },
    "Websockets": {
      "WebSocketConnectionManager": {
        "BufferSize": 16384,
        "MaxRetryAttempts": 5,
        "RetryDelays": [ 1000, 2000, 4000, 8000, 16000 ],
        "SignatureCacheDurationMinutes": 5,
        "ResetDelayMs": 5000,
        "SemaphoreTimeoutMs": 60000,
        "EnablePerformanceMetrics": true
      },
      "MessageProcessor": {
        "EnableMessageBatching": true,
        "MaxBatchSize": 50,
        "BatchProcessingIntervalMs": 100,
        "MaxSequenceNumbersToKeep": 10000,
        "EnablePerformanceMetrics": true,
        "PerformanceMetricsLogIntervalMs": 30000,
        "DuplicateMessageWarningThreshold": 10,
        "DuplicateMessageTimeWindowMs": 60000,
        "UseAdvancedLocking": true
      },
      "SubscriptionManager": {
        "EnableSubscriptionManagerMetrics": true,
        "SubscriptionTimeoutMs": 60000,
        "ConfirmationTimeoutSeconds": 60,
        "RetryDelayMs": 1000,
        "MaxQueueSize": 1000,
        "BatchSize": 10,
        "HealthCheckIntervalMs": 30000
      },
      "WebSocketMonitor": {
        "MonitoringIntervalMinutes": 1,
        "RetryDelayMinutes": 5,
        "EnableWebSocketMonitorMetrics": true
      },
      "KalshiWebSocketClient": {
        "EnableKalshiWebSocketClientPerformanceMetrics": true
      }
    }
  },
  "API": {
    "KalshiAPIService": {
      "EnablePerformanceMetrics": true
    }
  },
  "Communications": {
    "Logging": {
      "Environment": "dev",
      "StoreWebSocketEvents": true,
      "SqlDatabaseLogLevel": "Information",
      "ConsoleLogLevel": "Information"
    }
  },
  "SnapshotHandling": {
    "Snapshots": {
      "StorageDirectory": "\\\\DESKTOP-ITC50UT\\SmokehouseDataStorage\\NewSnapshots"
    },
    "DataLoader": {
      "EnableSnapshotValidation": true,
      "MinSnapshotCountForValidation": 1
    }
  },
  "Simulator": {
    "TradingSimulatorService": {
      "CacheDirectory": "..\\..\\..\\..\\..\\TestingOutput",
      "ProcessingTimeoutSeconds": 300,
      "MaxConcurrentMarkets": 5,
      "BatchSize": 10,
      "MarketDataFileNamePattern": "{market}_{label}_{strategy}_{timestamp}.json",
      "ResearchBusFileNamePattern": "{label}_ResearchBus_{timestamp}.csv",
      "BestFitReportFileNamePattern": "{label}_BestFitReport_{timestamp}.csv",
      "DiscrepancyThresholdPercentage": 10,
      "DiscrepancyDetection": {
        "Enabled": false,
        "VelocityThreshold": 0.1,
        "MinSnapshotsForDetection": 10
      }
    },
    "MarketTypeService": {
      "CacheExpirationMinutes": 30,
      "EnablePerformanceMetrics": true
    },
    "EquityCalculator": {
      "EnablePerformanceMetrics": true
    },
    "StrategySelectionHelper": {
      "EnablePerformanceMetrics": false
    },
    "SimulationEngine": {
      "EnablePerformanceMetrics": true
    },
    "PatternDetectionService": {
      "LookbackWindow": 50,
      "PatternTypes": [],
      "SignificancePriceThreshold": 0.01,
      "VolumeIncreaseMultiplier": 1.5,
      "InitialPatternCapacity": 10,
      "EnableParallelProcessing": true,
      "MaxDegreeOfParallelism": 4,
      "EnablePatternDetectionMetrics": false
    }
  },
  "WatchedMarkets": {
    "CandlestickService": {
      "MaxParallelCandlestickTasks": 4,
      "EnablePerformanceMetrics": true,
      "CandlestickMandatoryOverlapDaysMinute": 3,
      "CandlestickMandatoryOverlapDaysHour": 7,
      "CandlestickMandatoryOverlapDaysDay": 15,
      "HardDataStorageLocation": "\\\\DESKTOP-ITC50UT\\SmokehouseDataStorage"
    }
  },
  "GUI": {
    "SnapshotViewer": {
      "ZoomInFactor": 0.9,
      "ZoomOutFactor": 1.1,
      "PanThreshold": 0.001,
      "NavigationTimerInterval": 300,
      "NavigationResetDelay": 500,
      "RapidNavigationThreshold": 60,
      "FastNavigationThreshold": 15,
      "MediumNavigationThreshold": 5,
      "RapidStepSize": 60,
      "FastStepSize": 5,
      "MediumStepSize": 2,
      "NormalStepSize": 1
    },
    "Typography": {
      "PreferredFonts": [
        "Segoe UI",
        "Microsoft Sans Serif",
        "Arial",
        "Helvetica",
        "Tahoma",
        "Verdana",
        "Calibri",
        "System"
      ],
      "MonospaceFonts": [
        "Consolas",
        "Source Code Pro",
        "Fira Code",
        "Courier New",
        "Monaco",
        "Lucida Console",
        "DejaVu Sans Mono"
      ],
      "MinScaleFactor": 0.5,
      "MaxScaleFactor": 3.0,
      "DefaultScaleFactor": 1.0
    }
  }
}