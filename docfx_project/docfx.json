{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "BacklashBot/BacklashBot.sln"
          ]
        }
      ],
      "dest": "obj/api",
      "properties": {
        "TargetFramework": "net8.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": [ "obj/api/**.yml", "obj/api/index.md" ] },
      { "files": [ "articles/**.md", "articles/**.html" ] }
    ],
    "resource": [
      { "files": [ "articles/**.js", "articles/**.css" ] }
    ],
    "dest": "docs",
    "globalMetadata": {
      "_appTitle": "Kalshi Trading Bot Documentation",
      "_enableSearch": true,
      "_appFooter": "Generated by DocFX"
    }
  }
}