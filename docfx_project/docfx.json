{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "BacklashBot/BacklashBot.csproj",
            "KalshiBotAPI/KalshiBotAPI.csproj",
            "KalshiBotOverseer/KalshiBotOverseer.csproj",
            "BacklashDTOs/BacklashDTOs.csproj",
            "BacklashInterfaces/BacklashInterfaces.csproj",
            "KalshiBotLogging/KalshiBotLogging.csproj",
            "KalshiBotContext/KalshiBotData.csproj",
            "TradingStrategies/TradingStrategies.csproj",
            "TradingSimulator/TradingSimulator.csproj",
            "KalshiBotTasks/KalshiBotTasks.csproj",
            "BacklashPatterns/BacklashPatterns.csproj"
          ],
          "exclude": [
            "TradingGUI/**",
            "**/*Tests.csproj",
            "**/*.sln"
          ]
        }
      ],
      "dest": "obj/api",
      "properties": {
        "TargetFramework": "net8.0",
        "EnableWindowsTargeting": "true"
      }
    }
  ],
  "build": {
    "content": [
      { "files": [ "obj/api/**.yml" ], "dest": "api" },
      { "files": [ "index.md", "toc.yml" ] },
      { "files": [ "api/index.md", "api/toc.yml" ] },
      { "files": [ "articles/**.md", "articles/**.html" ] }
    ],
    "resource": [
      { "files": [ "articles/**.js", "articles/**.css" ] }
    ],
    "dest": "../docs",
    "globalMetadata": {
      "_appTitle": "Kalshi Trading Bot Documentation",
      "_enableSearch": true,
      "_appFooter": "Generated by DocFX"
    }
  }
}