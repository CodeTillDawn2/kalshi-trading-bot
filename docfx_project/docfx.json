{
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "**/bin/Debug/net8.0/*.*"
          ]
        }
      ],
      "dest": "obj/api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "obj/api/**.yml",
          "articles/**.md",
          "articles/**.html"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "articles/**.js",
          "articles/**.css"
        ]
      }
    ],
    "dest": "docs",
    "globalMetadata": {
      "_appTitle": "Kalshi Trading Bot Documentation",
      "_enableSearch": true,
      "_appFooter": "Generated by DocFX"
    }
  }
}